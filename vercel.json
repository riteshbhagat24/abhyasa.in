{
  "version": 2,
  "builds": [
    {
      "src": "*.php",
      "use": "vercel-php@0.7.3",
      "config": { "includeFiles": "{includes/**,config.php,data/**}" }
    },
    {
      "src": "api/*.php",
      "use": "vercel-php@0.7.3",
      "config": { "includeFiles": "{includes/**,config.php,data/**}" }
    },
    {
      "src": "admin/*.php",
      "use": "vercel-php@0.7.3",
      "config": { "includeFiles": "{includes/**,config.php,data/**}" }
    },
    { "src": "assets/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/config.php",       "status": 403 },
    { "src": "/includes/(.*)",    "status": 403 },
    { "src": "/data/(.*)",        "status": 403 },
    { "src": "/blog/([a-z0-9-]+)/?", "dest": "/blog-post.php?slug=$1" },
    { "handle": "filesystem" },
    { "src": "/([a-z0-9-]+)",     "dest": "/$1.php" },
    { "src": "/.*",               "dest": "/404.php", "status": 404 }
  ]
}
